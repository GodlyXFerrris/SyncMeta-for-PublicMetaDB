# SyncMeta – optional server-level overrides
# Most sync settings (API keys, lists, history) are configured per-profile in the web UI.

# --- Encryption ---
# Master key for encrypted profile credentials.
# Keep this stable across restarts/rebuilds — losing it invalidates all saved credentials.
# If unset, SyncMeta generates a key and saves it to the data directory (profiles.key).
SYNCMETA_MASTER_KEY=

# Optional: store the auto-generated key at a custom path instead of /app/data/profiles.key
# SYNCMETA_MASTER_KEY_FILE=/app/data/profiles.key

# --- Storage ---
# Where profiles are persisted. Mount a volume here to survive container restarts.
PROFILE_STORE_FILE=/app/data/profiles.json

# --- Admin Panel ---
# Set to enable the /admin panel (profile management, forced syncs, queue view).
# Leave unset to keep the admin panel disabled entirely.
# ADMIN_PASSWORD=

# --- Access Control ---
# Optional site-wide password gate shown before the main UI loads.
# Useful for extra protection on public-facing deployments.
# SITE_ACCESS_PASSWORD=

# --- Performance ---
# How many profile syncs can run in parallel (default: 4).
# SYNCMETA_MAX_CONCURRENT_SYNCS=4

# --- Scheduler ---
# Set to '1' to disable the background auto-sync scheduler.
# DISABLE_PROFILE_SCHEDULER=0

# --- Session & Rate Limiting (optional, sensible defaults shown) ---
# SYNCMETA_SESSION_TTL_SECONDS=2592000   # Browser session lifetime (default: 30 days)
# SYNCMETA_LOGIN_MAX_ATTEMPTS=10         # Failed logins before temporary lockout
# SYNCMETA_LOGIN_WINDOW_SECONDS=900      # Login rate-limit window in seconds
# SYNCMETA_ACCESS_MAX_ATTEMPTS=10        # Failed site-access attempts before lockout
# SYNCMETA_ACCESS_WINDOW_SECONDS=900     # Site-access rate-limit window in seconds
