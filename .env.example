# ── SIMKL ──────────────────────────────────────────────
# Create an app at https://simkl.com/settings/developer/
SIMKL_CLIENT_ID=your_simkl_client_id
SIMKL_CLIENT_SECRET=your_simkl_client_secret

# Run `python main.py auth` to get this token via PIN flow
SIMKL_ACCESS_TOKEN=

# ── AniList ────────────────────────────────────────────
# Set your username to enable AniList anime sync (replaces SIMKL anime lists)
ANILIST_USERNAME=

# AniList OAuth token (optional — only needed for private lists)
ANILIST_ACCESS_TOKEN=

# ── PublicMetaDB ───────────────────────────────────────
# Get your API key from https://publicmetadb.com/api-docs
PMDB_API_KEY=pm-your_api_key_here

# ── Sync options ───────────────────────────────────────
# Remove items from PMDB lists when they're no longer in SIMKL (true/false)
SYNC_REMOVE_MISSING=false

# Preview mode — log what would change without writing (true/false)
SYNC_DRY_RUN=false

# Run sync on a repeating interval (minutes, 0 = run once)
SYNC_INTERVAL_MINUTES=0

# Comma-separated media types to sync: shows,movies,anime
SYNC_MEDIA_TYPES=shows,movies,anime
