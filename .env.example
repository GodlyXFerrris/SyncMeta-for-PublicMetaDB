# Minimal optional overrides for the web app
# By default, most settings are configured via the web UI.

# --- Core Settings --- 
# Keep this stable if you want encrypted saved credentials to survive rebuilds, host moves, and fresh containers.
# If unset, SyncMeta generates a key and saves it to PROFILE_STORE_FILE_PATH/profiles.key
SYNCMETA_MASTER_KEY=

# Optional custom profile store path inside the container.
PROFILE_STORE_FILE=/app/data/profiles.json

# Optional: store the generated encryption key somewhere else.
# If unset, SyncMeta uses /app/data/profiles.key automatically.
# SYNCMETA_MASTER_KEY_FILE=/app/data/profiles.key

# --- Access Control & Security --- 
# Optional: enable a shared password before the app loads for basic site-wide protection.
# Leave commented out for normal public/self-hosted web use where profiles handle auth.
# SITE_ACCESS_PASSWORD=

# Optional session / login throttling settings
# SYNCMETA_SESSION_TTL_SECONDS=2592000  # Browser session lifetime in seconds (default: 30 days)
# SYNCMETA_LOGIN_MAX_ATTEMPTS=10        # Max login attempts before temporary lockout (default: 10)
# SYNCMETA_LOGIN_WINDOW_SECONDS=900     # Login rate-limit window in seconds (default: 15 minutes)
# SYNCMETA_ACCESS_MAX_ATTEMPTS=10       # Max site-access attempts before temporary lockout (default: 10)
# SYNCMETA_ACCESS_WINDOW_SECONDS=900    # Site-access rate-limit window in seconds (default: 15 minutes)

# --- Scheduler Control ---
# Optional: disable the background scheduler entirely. Set to '1' to disable.
# DISABLE_PROFILE_SCHEDULER=0
