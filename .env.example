# SyncMeta optional server-level overrides
# Most API keys, source lists, and sync rules are configured per profile in the web UI.

# --- Encryption ---
# Keep this stable across restarts. If unset, SyncMeta creates /app/data/profiles.key.
SYNCMETA_MASTER_KEY=
# SYNCMETA_MASTER_KEY_FILE=/app/data/profiles.key

# --- Storage ---
PROFILE_STORE_FILE=/app/data/profiles.json

# --- Admin / Access Control ---
# ADMIN_PASSWORD=
# SITE_ACCESS_PASSWORD=

# --- Small-VPS performance defaults ---
SYNCMETA_MAX_CONCURRENT_SYNCS=1
SYNCMETA_SOURCE_SYNC_WORKERS=2
SYNCMETA_SIMKL_FETCH_WORKERS=2
SYNCMETA_LIST_RESOLVE_WORKERS=2
SYNCMETA_LIST_WRITE_WORKERS=1
SYNCMETA_ACTIVITY_SOURCE_WORKERS=2
SYNCMETA_ACTIVITY_WRITE_WORKERS=1
SYNCMETA_MAPPING_WRITE_WORKERS=1
SYNCMETA_PREWARM_WORKERS=2
SYNCMETA_ANILIST_PREWARM_LIMIT=50

# --- Automatic schedule staggering ---
# Lists have a 6h minimum. History and resume have 24h minimums.
# Jitter keeps multiple profiles/modes from starting at exactly the same time.
SYNCMETA_SCHEDULE_JITTER_SECONDS=900
# SYNCMETA_LIST_SYNC_JITTER_SECONDS=900
# SYNCMETA_HISTORY_SYNC_JITTER_SECONDS=900
# SYNCMETA_RESUME_SYNC_JITTER_SECONDS=900

# --- Docker resource limits used by docker-compose.yml ---
SYNCMETA_CPU_LIMIT=1.0
SYNCMETA_MEMORY_LIMIT=1536m
SYNCMETA_MEMORY_RESERVATION=768m

# --- Gunicorn ---
SYNCMETA_GUNICORN_WORKERS=1
SYNCMETA_GUNICORN_THREADS=2
SYNCMETA_GUNICORN_TIMEOUT=120

# --- Scheduler ---
SYNCMETA_SCHEDULER_POLL_SECONDS=5
DISABLE_PROFILE_SCHEDULER=0

# --- Session & Rate Limiting ---
SYNCMETA_SESSION_TTL_SECONDS=2592000
SYNCMETA_LOGIN_MAX_ATTEMPTS=10
SYNCMETA_LOGIN_WINDOW_SECONDS=900
SYNCMETA_ACCESS_MAX_ATTEMPTS=10
SYNCMETA_ACCESS_WINDOW_SECONDS=900
