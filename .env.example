# Minimal optional overrides for the web app
#
# You do not need a .env file for normal dashboard use.
# Users can enter source credentials and sync selections in the web UI.

# Keep this stable if you want encrypted saved credentials to survive
# rebuilds, host moves, and fresh containers.
SYNCMETA_MASTER_KEY=

# Optional custom profile store path inside the container.
PROFILE_STORE_FILE=/app/data/profiles.json

# Optional: enable a shared password before the app loads.
# Leave commented out for normal public/self-hosted web use.
# SITE_ACCESS_PASSWORD=

# Optional session / login throttling
# SYNCMETA_SESSION_TTL_SECONDS=2592000
# SYNCMETA_LOGIN_MAX_ATTEMPTS=10
# SYNCMETA_LOGIN_WINDOW_SECONDS=900
# SYNCMETA_ACCESS_MAX_ATTEMPTS=10
# SYNCMETA_ACCESS_WINDOW_SECONDS=900

# Optional: store the generated encryption key somewhere else.
# If unset, SyncMeta uses /app/data/profiles.key automatically.
# SYNCMETA_MASTER_KEY_FILE=/app/data/profiles.key

# Optional: disable the background scheduler entirely.
# DISABLE_PROFILE_SCHEDULER=0
