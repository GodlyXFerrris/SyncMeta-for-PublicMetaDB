# Optional deployment settings for the web app

# Shared site access gate. Leave empty to disable.
SITE_ACCESS_PASSWORD=

# Keep this stable if you want encrypted saved credentials to survive rebuilds
# across hosts or clean container replacements.
SYNCMETA_MASTER_KEY=

# Optional custom profile store path inside the container.
PROFILE_STORE_FILE=/app/data/profiles.json

# Optional session / rate-limit tuning
SYNCMETA_SESSION_TTL_SECONDS=2592000
SYNCMETA_LOGIN_MAX_ATTEMPTS=10
SYNCMETA_LOGIN_WINDOW_SECONDS=900
SYNCMETA_ACCESS_MAX_ATTEMPTS=10
SYNCMETA_ACCESS_WINDOW_SECONDS=900

# Optional server-side source defaults / prefills
SIMKL_CLIENT_ID=
SIMKL_CLIENT_SECRET=
SIMKL_ACCESS_TOKEN=
ANILIST_USERNAME=
ANILIST_ACCESS_TOKEN=
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
TRAKT_ACCESS_TOKEN=
TRAKT_REFRESH_TOKEN=
MDBLIST_API_KEY=
PMDB_API_KEY=
